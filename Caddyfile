# Caddyfile — reverse proxy con HTTPS automático para el sistema de nómina.
#
# Caddy obtiene y renueva el certificado SSL de Let's Encrypt solo, sin que
# tengas que hacer nada. Solo necesitas que el dominio ya apunte (DNS tipo A)
# a la IP del VPS antes de arrancar Caddy.
#
# 1. Cambia "tudominio.com" por tu dominio real (en las dos líneas).
# 2. Coloca este archivo en /etc/caddy/Caddyfile
# 3. sudo systemctl reload caddy
#
# La app de Node debe estar corriendo en el puerto 3001 (con PM2).

tudominio.com, www.tudominio.com {
	# Redirige todo el tráfico al servidor Node/Express local
	reverse_proxy 127.0.0.1:3001

	# Compresión para que cargue más rápido
	encode gzip zstd

	# Cabeceras de seguridad básicas
	header {
		# Fuerza HTTPS en el navegador durante 1 año
		Strict-Transport-Security "max-age=31536000;"
		# Evita que el sitio se incruste en iframes de terceros (clickjacking)
		X-Frame-Options "SAMEORIGIN"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		# No revelar el servidor
		-Server
	}

	# Logs de acceso (útil para revisar quién entra)
	log {
		output file /var/log/caddy/nomina.log
		format console
	}
}
